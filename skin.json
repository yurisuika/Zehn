{
  "Conditions": {
    "Color Mode": {
      "description": "Choose your color.\n\nAuto mode will select either light or dark mode based on your system settings.",
      "tab": "Theme",
      "default": "Auto",
      "values": {
        "Auto": {
          "TargetCss": {
            "affects": [".*"],
            "src": "config/theme/mode/auto.css"
          }
        },
        "Dark": {
          "TargetCss": {
            "affects": [".*"],
            "src": "config/theme/mode/dark.css"
          }
        },
        "Light": {
          "TargetCss": {
            "affects": [".*"],
            "src": "config/theme/mode/light.css"
          }
        }
      }
    },
    "Transparency Effects": {
      "description": "Windows and surfaces appear translucent.\n\nEnables support for Reveal and Acrylic effects.\n\nAcrylic blurs behind supported windows when DWMX plugin is enabled.",
      "tab": "Theme",
      "default": "yes",
      "values": {
        "no": {
          "TargetCss": {
            "affects": [".*"],
            "src": "config/theme/transparency/disable.css"
          }
        },
        "yes": {
          "TargetCss": {
            "affects": [".*"],
            "src": "config/theme/transparency/enable.css"
          }
        }
      }
    },
    "Accent Color": {
