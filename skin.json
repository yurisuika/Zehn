    "Background Blend Amount": {
      "description": "Select how much color is blended into the theme's background. This includes window backgrounds and acrylic effects.\n\nLower values produce a better blend contrast, but higher values produce a truer color.\n\nYou may choose the color from the Colors section.",
      "tab": "Theme",
      "default": "0%",
      "values": {
        "0%": {
          "TargetCss": {
            "affects": [".*"],
            "src": "config/theme/blend/amount/background/0%.css"
          }
        },
        "25%": {
          "TargetCss": {
            "affects": [".*"],
            "src": "config/theme/blend/amount/background/25%.css"
          }
        },
        "50%": {
