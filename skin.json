    "Dark",
    "Light",
    "Metro",
    "Fluent",
    "Windows 10"
  ],
  "header_image": "https://raw.githubusercontent.com/yurisuika/Zehn/refs/heads/assets/header.gif",
  "splash_image": "https://raw.githubusercontent.com/yurisuika/Zehn/refs/heads/assets/splash.gif"
}