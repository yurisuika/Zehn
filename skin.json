  "Patches": [
    {
      "MatchRegexString": "Extensions",
      "TargetCss": "patches/plugins.css",
      "TargetJs": "patches/plugins.js"
    },
    {
      "MatchRegexString": ".Rp8QOGJ2DypeDniMnRBhr",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "https://.*.steampowered.com",
      "TargetCss": "patches/webkit.css",
      "TargetJs": "patches/webkit.js"
    },
    {
      "MatchRegexString": "https://steamcommunity.com",
      "TargetCss": "patches/webkit.css",
      "TargetJs": "patches/webkit.js"
    },
    {
      "MatchRegexString": "^Steam$",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "^OverlayBrowser_Browser$",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "^SP Overlay:",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "Supernav$",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "^notificationtoasts_",
      "TargetCss": "patches/notifications.css",
      "TargetJs": "patches/notifications.js"
    },
    {
      "MatchRegexString": "^SteamBrowser_Find$",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "^OverlayTab\\d+_Find$",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "^Steam Big Picture Mode$",
      "TargetCss": "patches/bigpicture.css",
      "TargetJs": "patches/bigpicture.js"
    },
    {
      "MatchRegexString": "^QuickAccess_",
      "TargetCss": "patches/bigpicture.css",
      "TargetJs": "patches/bigpicture.js"
    },
    {
      "MatchRegexString": "^MainMenu_",
      "TargetCss": "patches/bigpicture.css",
      "TargetJs": "patches/bigpicture.js"
    },
    {
      "MatchRegexString": ".friendsui-container",
      "TargetCss": "patches/friends.css",
      "TargetJs": "patches/friends.js"
    },
    {
      "MatchRegexString": "Menu$",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": ".ModalDialogPopup",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": ".FullModalOverlay",
      "TargetCss": "patches/library.css",
      "TargetJs": "patches/library.js"
    },
    {
      "MatchRegexString": "broadcaststatus",
      "TargetCss": "patches/broadcast.css",
      "TargetJs": "patches/broadcast.js"
    }
  ],
  "UseDefaultPatches": false,
  "Steam-WebKit": "patches/webkit.css",
  "RootColors": "config/colors.css",
  "name": "Zehn",
  "author": "yurisuika",
  "description": "Windows 10 Fluent Design for Steam - Minimal, colorable, light/dark, and more!",
  "source": "https://github.com/yurisuika/Zehn",
  "github": {
    "owner": "yurisuika",
    "repo_name": "Zehn"
  },
  "version": "2026.4.16",
  "tags": [
