{
  "Conditions": {
    "Avatar Shape": {
      "description": "Select the avatar shape.",
      "tab": "Personalization",
      "section": "Appearance",
      "default": "Round",
      "values": {
        "Round": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/appearance/avatar shape/round.css"
          }
        },
        "Square": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/appearance/avatar shape/square.css"
          }
        }
      }
    },
    "Scrollbar Style": {
      "description": "Select the style of scrollbar.",
      "tab": "Personalization",
      "section": "Appearance",
      "default": "Hidden",
      "values": {
        "Hidden": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/appearance/scrollbar style/hidden.css"
          }
        },
        "Windows": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/appearance/scrollbar style/windows.css"
          }
        },
        "Steam": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/appearance/scrollbar style/steam.css"
          }
        }
      }
    },
    "Color Mode": {
      "description": "Choose your color.\n\nAuto mode will select either light or dark mode based on your system settings.",
      "tab": "Personalization",
      "section": "Colors",
      "default": "Auto",
      "values": {
        "Auto": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/colors/color mode/auto.css"
          }
        },
        "Dark": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/colors/color mode/dark.css"
          }
        },
        "Light": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/colors/color mode/light.css"
          }
        }
      }
    },
    "Transparency Effects": {
      "description": "Windows and surfaces appear translucent. Enables support for Reveal and Acrylic effects.\n\nAllows behind-window blur when used with DWMX plugin.",
      "tab": "Personalization",
      "section": "Colors",
      "default": "yes",
      "values": {
        "no": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/colors/transparency effects/off.css"
          }
        },
        "yes": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/colors/transparency effects/on.css"
          }
        }
      }
    },
    "Show Accent Color on Window Borders": {
      "description": "Show accent color on window borders when focused.",
      "tab": "Personalization",
      "section": "Colors",
      "default": "yes",
      "values": {
        "no": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/colors/show accent color on window borders/off.css"
          }
        },
        "yes": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/colors/show accent color on window borders/on.css"
          }
        }
      }
    },
    "Background Color Mix": {
      "description": "Adjust how much color is blended into the background.",
      "tab": "Personalization",
      "section": "Themes",
      "default": 0,
      "slider": {
        "cssVariable": "--option-background-color-mix",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%"
      }
    },
    "Foreground Color Mix": {
      "description": "Adjust how much color is blended into the foreground.",
      "tab": "Personalization",
      "section": "Themes",
      "default": 0,
      "slider": {
        "cssVariable": "--option-foreground-color-mix",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%"
      }
    },
    "Color Space": {
      "description": "Select the color space used in blending.",
      "tab": "Personalization",
      "section": "Themes",
      "default": "sRGB",
      "values": {
        "sRGB": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/themes/color space/srgb.css"
