{
  "Conditions": {
    "Avatar Shape": {
      "description": "Select the avatar shape.",
      "tab": "Personalization",
      "section": "Appearance",
      "default": "Round",
      "values": {
        "Round": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/appearance/avatar shape/round.css"
          }
        },
        "Square": {
          "TargetCss": {
            "affects": [".*"],
            "src": "option/personalization/appearance/avatar shape/square.css"
          }
        }
      }
