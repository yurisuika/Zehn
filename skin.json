  "Patches": [
    {
      "MatchRegexString": "Extensions",
      "TargetCss": "patch/plugins.css",
      "TargetJs": "patch/plugins.js"
    },
    {
      "MatchRegexString": ".l25AfossKXBOZGYoty0tM",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "/Iniciar a sessão no Steam|Вписване в Steam|Přihlášení do služby Steam|Log på Steam|Aanmelden bij Steam|Sign in to Steam|Kirjaudu Steamiin|Se connecter à Steam|Bei Steam anmelden|Σύνδεση στο Steam|Bejelentkezés a Steambe|Login ke Steam|Accedi a Steam|Steamにサインイン|Steam 로그인|Iniciar sesión en Steam|Logg inn på Steam|Zaloguj się do Steam|Iniciar sessão no Steam|Conectează-te la Steam|Войти в Steam|登录蒸汽平台|登录 Steam|Iniciar sesión en Steam|Logga in på Steam|登入 Steam|เข้าสู่ระบบ Steam|Steam'e Giriş Yap|Увійти до Steam|Đăng nhập vào Steam/",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "https://.*.steampowered.com",
      "TargetCss": "patch/webkit.css",
      "TargetJs": "patch/webkit.js"
    },
    {
      "MatchRegexString": "https://steamcommunity.com",
      "TargetCss": "patch/webkit.css",
      "TargetJs": "patch/webkit.js"
    },
    {
      "MatchRegexString": "^Steam$",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "/Steam — Lista de jogos|Steam: spellenlijst|Liste der Steam-Spiele|Steam : liste de jeux|Steam-pelien lista|Lista jocurilor de pe Steam|Steam-spilliste|Steam – seznam her|Steam Games List|Danh sách trò chơi Steam|Списък със Steam игри|Λίστα παιχνιδιών Steam|Steam-spellista|Steam 游戏列表|Steam 게임 목록|Steam – liste over spill|Список игр в Steam|Steam: Lista de jogos|蒸汽平台游戏列表|รายชื่อเกมบน Steam|Lista de juegos de Steam|Cписок ігор у Steam|Steam 遊戲列表|Lista de juegos de Steam|Steam Oyun Listesi|Daftar Game Steam|Steamゲームリスト|Lista gier Steam|Steam játéklista|Elenco dei giochi di Steam/",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "^OverlayBrowser_Browser$",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "^SP Overlay:",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "Supernav$",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "^notificationtoasts_",
      "TargetCss": "patch/notifications.css",
      "TargetJs": "patch/notifications.js"
    },
    {
      "MatchRegexString": "^SteamBrowser_Find$",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "^OverlayTab\\d+_Find$",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "^Steam Big Picture Mode$",
      "TargetCss": "patch/bigpicture.css",
      "TargetJs": "patch/bigpicture.js"
    },
    {
      "MatchRegexString": "^QuickAccess_",
      "TargetCss": "patch/bigpicture.css",
      "TargetJs": "patch/bigpicture.js"
    },
    {
      "MatchRegexString": "^MainMenu_",
      "TargetCss": "patch/bigpicture.css",
      "TargetJs": "patch/bigpicture.js"
    },
    {
      "MatchRegexString": ".SavedDimensionsPopup",
      "TargetCss": "patch/friends.css",
      "TargetJs": "patch/friends.js"
    },
    {
      "MatchRegexString": ".ChatPopup",
      "TargetCss": "patch/friends.css",
      "TargetJs": "patch/friends.js"
    },
    {
      "MatchRegexString": ".HoverPopup",
      "TargetCss": "patch/friends.css",
      "TargetJs": "patch/friends.js"
    },
    {
      "MatchRegexString": "Menu$",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": ".ModalDialogPopup",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": ".FullModalOverlay",
      "TargetCss": "patch/library.css",
      "TargetJs": "patch/library.js"
    },
    {
      "MatchRegexString": "broadcaststatus",
      "TargetCss": "patch/broadcast.css",
      "TargetJs": "patch/broadcast.js"
    }
  ],
  "UseDefaultPatches": false,
  "Steam-WebKit": "patch/webkit.css",
  "RootColors": "option/colors.css",
